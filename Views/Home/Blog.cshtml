@model IEnumerable<Counselor.Models.Blog>
@{
    ViewData["Title"] = "Blog";
}

<section class="hero-wrap hero-wrap-2" style="background-image: url('/Html/images/bg_5.jpg');" data-stellar-background-ratio="0.5">
  <div class="overlay"></div>
  <div class="container">
    <div class="row no-gutters slider-text align-items-end justify-content-center">
      <div class="col-md-9 ftco-animate mb-5 text-center">
        <p class="breadcrumbs mb-0"><span class="mr-2"><a href="/">Home <i class="fa fa-chevron-right"></i></a></span> <span>Blog <i class="fa fa-chevron-right"></i></span></p>
        <h1 class="mb-0 bread">Our Blog</h1>
      </div>
    </div>
  </div>
</section>

<section class="ftco-section">
  <div class="container">
    <div class="row d-flex">
      @if (Model != null && Model.Any())
      {
        @foreach (var blog in Model)
        {
          <div class="col-md-4 d-flex ftco-animate">
            <div class="blog-entry justify-content-end">
              <div class="text text-center">
                <a asp-action="BlogSingle" asp-route-id="@blog.Id" class="block-20 img" style="background-image: url('/Html/images/image_1.jpg');"></a>
                <div class="meta text-center mb-2 d-flex align-items-center justify-content-center">
                  <div>
                    <span class="day">@blog.PublishedDate.Day</span>
                    <span class="mos">@blog.PublishedDate.ToString("MMMM")</span>
                    <span class="yr">@blog.PublishedDate.Year</span>
                  </div>
                </div>
                <h3 class="heading mb-3"><a asp-action="BlogSingle" asp-route-id="@blog.Id">@blog.Title</a></h3>
                <p>@(blog.Summary ?? (blog.Content.Length > 150 ? blog.Content.Substring(0, 150) + "..." : blog.Content))</p>
                @if (!string.IsNullOrEmpty(blog.Author))
                {
                  <p class="text-muted"><small><i class="fa fa-user mr-1"></i>By @blog.Author</small></p>
                }
              </div>
            </div>
          </div>
        }
      }
      else
      {
        <div class="col-12">
          <div class="alert alert-info text-center" role="alert">
            <i class="fa fa-info-circle fa-2x mb-2"></i>
            <h5>No Blog Posts Available</h5>
            <p class="mb-0">Check back soon for new content!</p>
          </div>
        </div>
      }
    </div>
  </div>
</section>
