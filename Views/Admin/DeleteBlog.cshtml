@model Counselor.Models.Blog
@{
    ViewData["Title"] = "Delete Blog";
}

<div class="container mt-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Admin Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-action="Blogs">Manage Blogs</a></li>
            <li class="breadcrumb-item active" aria-current="page">Delete Blog</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-md-8 offset-md-2">
            <div class="card border-danger">
                <div class="card-header bg-danger text-white">
                    <h3 class="mb-0"><i class="fa fa-exclamation-triangle"></i> Confirm Delete</h3>
                </div>
                <div class="card-body">
                    <div class="alert alert-danger">
                        <strong>Warning!</strong> Are you sure you want to delete this blog post? This action cannot be undone.
                    </div>

                    <h4>@Model.Title</h4>
                    
                    <dl class="row mt-4">
                        <dt class="col-sm-3">Author:</dt>
                        <dd class="col-sm-9">@(Model.Author ?? "Anonymous")</dd>

                        <dt class="col-sm-3">Published Date:</dt>
                        <dd class="col-sm-9">@Model.PublishedDate.ToString("MMMM dd, yyyy")</dd>

                        <dt class="col-sm-3">Status:</dt>
                        <dd class="col-sm-9">
                            @if (Model.IsPublished)
                            {
                                <span class="badge badge-success">Published</span>
                            }
                            else
                            {
                                <span class="badge badge-secondary">Draft</span>
                            }
                        </dd>

                        <dt class="col-sm-3">Created:</dt>
                        <dd class="col-sm-9">@Model.CreatedAt.ToString("MMMM dd, yyyy hh:mm tt")</dd>

                        @if (Model.UpdatedAt.HasValue)
                        {
                            <dt class="col-sm-3">Last Updated:</dt>
                            <dd class="col-sm-9">@Model.UpdatedAt.Value.ToString("MMMM dd, yyyy hh:mm tt")</dd>
                        }

                        @if (!string.IsNullOrEmpty(Model.Summary))
                        {
                            <dt class="col-sm-3">Summary:</dt>
                            <dd class="col-sm-9">@Model.Summary</dd>
                        }
                    </dl>

                    <hr />

                    <form asp-action="DeleteBlog" method="post">
                        <input type="hidden" asp-for="Id" />
                        
                        <div class="d-flex justify-content-between">
                            <a asp-action="Blogs" class="btn btn-secondary">
                                <i class="fa fa-arrow-left"></i> Cancel
                            </a>
                            <button type="submit" class="btn btn-danger">
                                <i class="fa fa-trash"></i> Delete Blog Post
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
