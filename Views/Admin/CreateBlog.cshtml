@model Counselor.Models.Blog
@{
    ViewData["Title"] = "Create Blog";
}

<div class="container mt-5">
    <nav aria-label="breadcrumb">
        <ol class="breadcrumb">
            <li class="breadcrumb-item"><a asp-action="Index">Admin Dashboard</a></li>
            <li class="breadcrumb-item"><a asp-action="Blogs">Manage Blogs</a></li>
            <li class="breadcrumb-item active" aria-current="page">Create Blog</li>
        </ol>
    </nav>

    <div class="row">
        <div class="col-md-10 offset-md-1">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0">Create New Blog Post</h3>
                </div>
                <div class="card-body">
                    <form asp-action="CreateBlog" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

                        <div class="form-group">
                            <label asp-for="Title" class="font-weight-bold"></label>
                            <input asp-for="Title" class="form-control" placeholder="Enter blog title" />
                            <span asp-validation-for="Title" class="text-danger"></span>
                        </div>

                        <div class="form-group">
                            <label asp-for="Summary" class="font-weight-bold"></label>
                            <textarea asp-for="Summary" class="form-control" rows="3" placeholder="Brief summary of the blog post (optional)"></textarea>
                            <span asp-validation-for="Summary" class="text-danger"></span>
                            <small class="form-text text-muted">This will be shown on the blog listing page.</small>
                        </div>

                        <div class="form-group">
                            <label asp-for="Content" class="font-weight-bold"></label>
                            <textarea asp-for="Content" class="form-control" rows="15" placeholder="Write your blog content here..."></textarea>
                            <span asp-validation-for="Content" class="text-danger"></span>
                            <small class="form-text text-muted">You can use HTML formatting in your content.</small>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="Author" class="font-weight-bold"></label>
                                    <input asp-for="Author" class="form-control" placeholder="Author name (optional)" />
                                    <span asp-validation-for="Author" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="form-group">
                                    <label asp-for="PublishedDate" class="font-weight-bold"></label>
                                    <input asp-for="PublishedDate" type="datetime-local" class="form-control" />
                                    <span asp-validation-for="PublishedDate" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="form-group">
                            <div class="custom-control custom-checkbox">
                                <input asp-for="IsPublished" class="custom-control-input" id="isPublished" />
                                <label class="custom-control-label" for="isPublished">
                                    Publish immediately
                                </label>
                            </div>
                            <small class="form-text text-muted">Uncheck to save as draft.</small>
                        </div>

                        <hr />

                        <div class="d-flex justify-content-between">
                            <a asp-action="Blogs" class="btn btn-secondary">
                                <i class="fa fa-arrow-left"></i> Cancel
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="fa fa-save"></i> Create Blog Post
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        // Set default published date to now if empty
        $(document).ready(function() {
            var dateInput = $('input[type="datetime-local"]');
            if (!dateInput.val()) {
                var now = new Date();
                now.setMinutes(now.getMinutes() - now.getTimezoneOffset());
                dateInput.val(now.toISOString().slice(0, 16));
            }
        });
    </script>
}
