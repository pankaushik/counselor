@model dynamic
@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container mt-5">
    <h1 class="mb-4"><i class="fa fa-dashboard"></i> Admin Dashboard</h1>

    <div class="row">
        <!-- Blog Statistics -->
        <div class="col-md-4 mb-4">
            <div class="card border-primary">
                <div class="card-body text-center">
                    <i class="fa fa-file-text fa-3x text-primary mb-3"></i>
                    <h3 class="mb-0">@Model.TotalBlogs</h3>
                    <p class="text-muted mb-0">Total Blogs</p>
                    <hr />
                    <div class="d-flex justify-content-around">
                        <div>
                            <strong>@Model.PublishedBlogs</strong>
                            <br />
                            <small class="text-success">Published</small>
                        </div>
                        <div>
                            <strong>@Model.DraftBlogs</strong>
                            <br />
                            <small class="text-secondary">Drafts</small>
                        </div>
                    </div>
                </div>
            </div>
        </div>

        <!-- Appointment Statistics -->
        <div class="col-md-4 mb-4">
            <div class="card border-success">
                <div class="card-body text-center">
                    <i class="fa fa-calendar fa-3x text-success mb-3"></i>
                    <h3 class="mb-0">@Model.TotalAppointments</h3>
                    <p class="text-muted mb-0">Total Appointments</p>
                    <hr />
                    <div>
                        <strong>@Model.UpcomingAppointments</strong>
                        <br />
                        <small class="text-success">Upcoming</small>
                    </div>
                </div>
            </div>
        </div>

        <!-- Quick Actions -->
        <div class="col-md-4 mb-4">
            <div class="card border-info">
                <div class="card-body">
                    <h5 class="card-title"><i class="fa fa-bolt"></i> Quick Actions</h5>
                    <div class="list-group list-group-flush">
                        <a asp-action="CreateBlog" class="list-group-item list-group-item-action">
                            <i class="fa fa-plus text-primary"></i> Create New Blog
                        </a>
                        <a asp-action="Blogs" class="list-group-item list-group-item-action">
                            <i class="fa fa-list text-info"></i> Manage Blogs
                        </a>
                        <a asp-controller="Appointment" asp-action="Index" class="list-group-item list-group-item-action">
                            <i class="fa fa-calendar text-success"></i> View Appointments
                        </a>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Management Sections -->
    <div class="row mt-4">
        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0"><i class="fa fa-newspaper-o"></i> Blog Management</h5>
                </div>
                <div class="card-body">
                    <p>Manage your blog posts, create new articles, and publish content for your website.</p>
                    <div class="d-flex gap-2">
                        <a asp-action="CreateBlog" class="btn btn-primary mr-2">
                            <i class="fa fa-plus"></i> New Blog
                        </a>
                        <a asp-action="Blogs" class="btn btn-outline-primary">
                            <i class="fa fa-list"></i> View All Blogs
                        </a>
                    </div>
                </div>
            </div>
        </div>

        <div class="col-md-6 mb-4">
            <div class="card">
                <div class="card-header bg-success text-white">
                    <h5 class="mb-0"><i class="fa fa-calendar-check-o"></i> Appointment Management</h5>
                </div>
                <div class="card-body">
                    <p>View and manage client appointments, schedule new sessions, and track upcoming consultations.</p>
                    <a asp-controller="Appointment" asp-action="Index" class="btn btn-success">
                        <i class="fa fa-calendar"></i> Manage Appointments
                    </a>
                </div>
            </div>
        </div>
    </div>

    <!-- Recent Activity -->
    <div class="row mt-4">
        <div class="col-12">
            <div class="card">
                <div class="card-header bg-info text-white">
                    <h5 class="mb-0"><i class="fa fa-clock-o"></i> Getting Started</h5>
                </div>
                <div class="card-body">
                    <ul class="list-unstyled">
                        <li class="mb-2"><i class="fa fa-check-circle text-success"></i> Create and publish blog posts</li>
                        <li class="mb-2"><i class="fa fa-check-circle text-success"></i> Manage client appointments</li>
                        <li class="mb-2"><i class="fa fa-check-circle text-success"></i> Monitor website content</li>
                        <li class="mb-2"><i class="fa fa-check-circle text-success"></i> Update and maintain your counseling platform</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .card {
        transition: transform 0.2s;
    }

    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 4px 8px rgba(0,0,0,0.2);
    }

    .fa-3x {
        font-size: 3rem;
    }
</style>
